---
import Layout from '@/layouts/Layout.astro';
import { loadAdrCatalog, repoLink } from '@/lib/content';
import { portalConfig } from '@/lib/portal-config';

const cfg = portalConfig();
const adrs = loadAdrCatalog();
const recentAdrs = adrs.slice(0, 8);
const decisionsDir = cfg.decisions.dir;
const decisionsIndexLink = repoLink(decisionsDir);

interface BuildSurface {
  title: string;
  description: string;
  href: string;
  meta: string;
}

// SURFACES come from blueprint.yml's portal.surfaces block. Empty at Tier-0;
// REPLACE_FOR_PROJECT: add integration surfaces (API refs, SDKs, component
// libraries, design tokens) as the initiative ships them.
const SURFACES: BuildSurface[] = cfg.surfaces.map((s: any) => ({
  title: String(s?.title ?? ''),
  description: String(s?.description ?? ''),
  href: String(s?.href ?? ''),
  meta: String(s?.meta ?? ''),
}));
const hasSurfaces = cfg.features.surfaces && SURFACES.length > 0;
---
<Layout title="Build" description="Integrate it. API, ADRs, components, and the surfaces this initiative ships.">
  <header class="mb-10 max-w-3xl">
    <p class="mb-2 font-mono text-xs uppercase tracking-wide text-info">Build</p>
    <h1 class="mb-3 font-heading text-4xl font-semibold leading-tight tracking-tight">
      Integrate it.
    </h1>
    <p class="text-lg leading-relaxed text-contrast-500">
      The integration layer for this initiative — APIs, SDKs, component libraries, and decision records. Each surface links to its source.
    </p>
  </header>

  {hasSurfaces ? (
    <section class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {SURFACES.map((s) => (
        <a
          href={s.href}
          target="_blank"
          rel="noreferrer"
          class="group block rounded-lg border border-contrast-200 bg-background p-5 transition-colors hover:border-brand/60"
        >
          <h3 class="mb-1 font-heading text-base font-semibold tracking-tight text-foreground group-hover:text-brand">
            {s.title}
          </h3>
          <p class="mb-3 text-sm leading-relaxed text-contrast-500">{s.description}</p>
          {s.meta && (
            <p class="font-mono text-[10px] uppercase tracking-wide text-contrast-400">{s.meta}</p>
          )}
        </a>
      ))}
    </section>
  ) : (
    <section class="mt-10 rounded-lg border border-dashed border-contrast-300 bg-background p-5">
      <p class="mb-1 font-mono text-[10px] uppercase tracking-wide text-contrast-400">Not configured</p>
      <p class="text-sm leading-relaxed text-contrast-500">
        No integration surfaces are configured for this initiative yet. Add them to <code class="font-mono text-xs">blueprint.yml</code> under <code class="font-mono text-xs">portal.surfaces</code> as the initiative ships APIs, SDKs, or component libraries.
      </p>
    </section>
  )}

  {recentAdrs.length > 0 && (
    <section class="mt-12">
      <header class="mb-4 flex items-end justify-between">
        <div>
          <h2 class="font-heading text-2xl font-semibold tracking-tight">Latest decisions</h2>
          <p class="mt-1 text-sm text-contrast-500">
            {adrs.length} ratified {adrs.length === 1 ? 'ADR' : 'ADRs'} · most recent first
          </p>
        </div>
        {decisionsIndexLink && (
          <a
            href={decisionsIndexLink}
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-[11px] uppercase tracking-wide text-brand hover:underline"
          >
            full index →
          </a>
        )}
      </header>
      <ol class="divide-y divide-contrast-100 rounded-lg border border-contrast-200 bg-background">
        {recentAdrs.map((adr) => {
          const adrLink = repoLink(`${decisionsDir}/${adr.filename}`);
          return (
            <li class="flex items-center gap-4 px-4 py-3 transition-colors duration-fast ease-standard hover:bg-contrast-100/40">
              <span class="w-14 shrink-0 font-mono text-xs font-medium uppercase tracking-wide text-contrast-400">
                ADR-{String(adr.number).padStart(4, '0')}
              </span>
              {adrLink ? (
                <a
                  href={adrLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 text-sm text-foreground hover:text-brand"
                >
                  {adr.title}
                </a>
              ) : (
                <span class="flex-1 text-sm text-foreground">{adr.title}</span>
              )}
            </li>
          );
        })}
      </ol>
    </section>
  )}
</Layout>
