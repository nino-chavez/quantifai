---
import Layout from '@/layouts/Layout.astro';
---
<!--
  REPLACE_FOR_PROJECT — this surface carries example/placeholder content from the
  Blueprint reference template. Populate it from your initiative's deliverables (or
  delete it) before sharing with stakeholders. The portal-initiative-conformance-
  reviewer treats this banner as a block — resolve before sharing.
-->
<Layout
  title="Strategic fork — Strategy"
  description="REPLACE_FOR_PROJECT: document the strategic fork specific to this initiative."
>
  <header class="mb-8 max-w-3xl">
    <p class="mb-2 font-mono text-xs uppercase tracking-wide text-info">
      <a href="/strategy" class="hover:underline">Strategy</a> → Strategic fork
    </p>
    <h1 class="mb-3 font-heading text-4xl font-semibold leading-tight tracking-tight">
      REPLACE_FOR_PROJECT: strategic fork title.
    </h1>
    <p class="text-lg leading-relaxed text-contrast-500">
      Document the open strategic fork for this initiative: what the two or more paths are,
      what the decision criteria are, and what would need to be true for each path.
    </p>
  </header>

  <div class="rounded-lg border border-warning/30 bg-warning-background/20 p-5">
    <p class="font-mono text-[11px] uppercase tracking-wide text-warning-foreground mb-2">REPLACE_FOR_PROJECT</p>
    <p class="text-sm text-contrast-500">
      This page is a skeleton. Replace with the strategic fork analysis for this initiative.
      Delete this file entirely if the initiative has no open strategic fork.
    </p>
    <p class="mt-3 text-sm text-contrast-500">
      See <code class="font-mono text-xs">docs/strategy/</code> for source markdown artifacts.
    </p>
  </div>
</Layout>
