# Copy to .env. ADR-0005: pure Cloudflare (Workers + D1 + Access) — no
# Supabase/Postgres stack to run locally anymore.

# Importer config (scripts/import-claude-jsonl.ts, scripts/import-git-events.ts).
# Default mode POSTs to the deployed ingest endpoint — both required:
QUANTIFAI_API_URL=https://quantifai-app.biq.workers.dev
QUANTIFAI_API_KEY=

# --local flag writes directly to the local D1 file via `wrangler d1 execute`
# instead (no API URL/key needed for that path).

# Repos scanned for git_events (ADR-0004 v0: this repo + platform)
QUANTIFAI_GIT_REPOS=/Users/nino/Workspace/dev/wip/quantifai-next,/Users/nino/Workspace/dev/wip/quantifai-platform
