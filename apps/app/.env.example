# Copy to .env. Values below are `npx supabase start`'s own printed local
# dev credentials (fixed, non-secret — the local stack binds to 127.0.0.1
# only). Re-run `npx supabase start` and paste its printed values if yours differ.
PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres

# Importer config — repos scanned for git_events (ADR-0004 v0: this repo + platform)
QUANTIFAI_GIT_REPOS=/Users/nino/Workspace/dev/wip/quantifai-next,/Users/nino/Workspace/dev/wip/quantifai-platform
