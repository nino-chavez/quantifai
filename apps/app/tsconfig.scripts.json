{
	"compilerOptions": {
		"target": "es2022",
		"module": "esnext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"types": ["node"]
	},
	"include": ["scripts/**/*.ts", "src/lib/importers/**/*.ts", "src/lib/attribution/**/*.ts", "src/lib/adapters/**/*.ts", "src/lib/pricing/**/*.ts"],
	"exclude": ["**/*.test.ts", "**/*.svelte.ts"]
}
