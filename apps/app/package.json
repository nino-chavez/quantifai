{
	"name": "@quantifai/app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"postbuild": "node scripts/patch-worker-scheduled.mjs",
		"preview": "npm run build && wrangler dev",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p tsconfig.scripts.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"lint": "eslint .",
		"import:claude": "tsx scripts/import-claude-jsonl.ts",
		"import:git": "tsx scripts/import-git-events.ts",
		"hooks:install": "tsx scripts/install-git-hook.ts",
		"seed:plan": "tsx scripts/seed-subscription-plan.ts",
		"deploy": "npm run build && wrangler deploy",
		"db:migrate:local": "wrangler d1 migrations apply quantifai --local",
		"db:migrate:remote": "wrangler d1 migrations apply quantifai --remote",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260701.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-cloudflare": "^7.2.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.2",
		"@types/node": "^22",
		"eslint": "^10.4.1",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.20.6",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"wrangler": "^4.50.0"
	}
}
