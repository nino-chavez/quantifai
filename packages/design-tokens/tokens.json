{
  "$schema": "./tokens.schema.json",
  "meta": {
    "namespace": "bcs",
    "colorFormat": "oklch",
    "rationale": "OKLCH chosen over HSL/RGB for perceptually uniform lightness — derived backgrounds and foregrounds from a brand triplet stay readable at every step. Storefront-kit (BC) uses the same approach; we share that idiom intentionally."
  },
  "color": {
    "brand": {
      "lch": "0.55 0.13 215",
      "background": { "derived": true, "L": 0.97, "C": 0.03 },
      "foreground": { "derived": true, "L": 0.28, "C": 0.06 }
    },
    "success": {
      "lch": "0.72 0.17 152",
      "background": { "derived": true, "L": 0.97, "C": 0.04 },
      "foreground": { "derived": true, "L": 0.32, "C": 0.09 }
    },
    "error": {
      "lch": "0.62 0.22 28",
      "background": { "derived": true, "L": 0.96, "C": 0.04 },
      "foreground": { "derived": true, "L": 0.32, "C": 0.12 }
    },
    "warning": {
      "lch": "0.78 0.16 78",
      "background": { "derived": true, "L": 0.97, "C": 0.04 },
      "foreground": { "derived": true, "L": 0.36, "C": 0.10 }
    },
    "info": {
      "lch": "0.62 0.13 245",
      "background": { "derived": true, "L": 0.97, "C": 0.03 },
      "foreground": { "derived": true, "L": 0.32, "C": 0.08 }
    },
    "neutral": {
      "background": "1 0 0",
      "foreground": "0.16 0 0",
      "contrast": {
        "100": "0.96 0 0",
        "200": "0.88 0 0",
        "300": "0.78 0 0",
        "400": "0.62 0 0",
        "500": "0.42 0 0"
      }
    }
  },
  "font": {
    "heading": "'Inter Display', 'Inter', system-ui, -apple-system, sans-serif",
    "body": "'Inter', system-ui, -apple-system, sans-serif",
    "mono": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace"
  },
  "fontSize": {
    "xs":   { "size": "0.75rem",  "lineHeight": "1.125rem" },
    "sm":   { "size": "0.875rem", "lineHeight": "1.25rem" },
    "base": { "size": "1rem",     "lineHeight": "1.5rem" },
    "lg":   { "size": "1.125rem", "lineHeight": "1.75rem", "letterSpacing": "-0.01em" },
    "xl":   { "size": "1.25rem",  "lineHeight": "1.75rem", "letterSpacing": "-0.01em" },
    "2xl":  { "size": "1.5rem",   "lineHeight": "2rem",    "letterSpacing": "-0.015em" },
    "3xl":  { "size": "1.875rem", "lineHeight": "2.25rem", "letterSpacing": "-0.02em" },
    "4xl":  { "size": "2.5rem",   "lineHeight": "2.75rem", "letterSpacing": "-0.022em" },
    "5xl":  { "size": "3rem",     "lineHeight": "3.25rem", "letterSpacing": "-0.025em" },
    "6xl":  { "size": "3.75rem",  "lineHeight": "4rem",    "letterSpacing": "-0.028em" },
    "7xl":  { "size": "4.5rem",   "lineHeight": "1",       "letterSpacing": "-0.032em" },
    "8xl":  { "size": "6rem",     "lineHeight": "1",       "letterSpacing": "-0.035em" }
  },
  "spacing": {
    "0":  "0",
    "1":  "0.25rem",
    "2":  "0.5rem",
    "3":  "0.75rem",
    "4":  "1rem",
    "5":  "1.25rem",
    "6":  "1.5rem",
    "8":  "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem",
    "32": "8rem"
  },
  "radius": {
    "xs":  "0.25rem",
    "sm":  "0.375rem",
    "md":  "0.5rem",
    "lg":  "0.75rem",
    "xl":  "1rem",
    "2xl": "1.5rem",
    "full": "9999px"
  },
  "motion": {
    "duration": {
      "instant": "100ms",
      "fast":    "150ms",
      "normal":  "200ms",
      "slow":    "300ms",
      "deliberate": "500ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "decel":    "cubic-bezier(0, 0, 0.2, 1)",
      "accel":    "cubic-bezier(0.4, 0, 1, 1)",
      "spring":   "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  },
  "focus": {
    "ringWidth": "2px",
    "ringOffset": "2px"
  },
  "shadow": {
    "sm": "0 1px 2px 0 oklch(0 0 0 / 0.04)",
    "md": "0 4px 8px -2px oklch(0 0 0 / 0.08), 0 2px 4px -2px oklch(0 0 0 / 0.04)",
    "lg": "0 12px 24px -8px oklch(0 0 0 / 0.10), 0 4px 8px -4px oklch(0 0 0 / 0.06)",
    "xl": "0 24px 48px -12px oklch(0 0 0 / 0.14)"
  }
}
